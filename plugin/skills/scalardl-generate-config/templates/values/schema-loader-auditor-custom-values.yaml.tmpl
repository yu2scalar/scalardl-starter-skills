# Helm chart: schema-loading
# Purpose: create ScalarDL Auditor system tables in the Auditor's ScalarDB
# instance (which MUST be different from the Ledger's ScalarDB — Byzantine
# fault detection requires separate management domains).
#
# Apply with:
#   helm install <release>-schema-loader-auditor scalar-labs/schema-loading \
#     -f schema-loader-auditor-custom-values.yaml
# After the Job completes successfully, the Auditor pod can start.

schemaLoading:
  # Type of schema to apply: "auditor" creates Auditor system tables
  schemaType: auditor

  # databaseProperties path (same rationale as ledger schema-loader): mount
  # full ScalarDB config so credentials stay as ${env:VAR} references.
  databaseProperties: |
    scalar.db.contact_points={{auditorScalarDbContactPoints}}
    scalar.db.username=${env:SCALAR_DB_USERNAME}
    scalar.db.password=${env:SCALAR_DB_PASSWORD}
    scalar.db.storage={{auditorScalarDbStorage}}

  # Mount auditor-credentials-secret via envFrom so SCALAR_DB_USERNAME /
  # SCALAR_DB_PASSWORD are populated for the Auditor's DB connection.
  secretName: auditor-credentials-secret

  commandArgs: []

# Notes:
# - Run this Job BEFORE installing the Auditor Helm release.
# - The Auditor's ScalarDB MUST be a different infrastructure from the Ledger's;
#   sharing them defeats the Byzantine-fault-detection design. Verify that
#   `contactPoints` here points to a DIFFERENT cluster / endpoint than the
#   Ledger's schema-loader values.
# - Skill defaults nudge users in this direction (Ledger contactPoints =
#   "cassandra", Auditor contactPoints = "cassandra-auditor"), but you should
#   confirm the actual deploy targets independent storage.
