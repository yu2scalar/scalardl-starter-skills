# Generated by scalardl-starter-skills/scalardl-generate-config (Auditor=Yes only)
# Plan: plan-008 (scalardl-generate-config skill design)
# Reference (synced): skills/scalardl-generate-config/references/scalardl-configurations.md
# Generated at: {{generatedAt}}
# Target ScalarDL: {{targetVersion}}+
# Helm chart: scalardl-audit (note: chart name is "scalardl-audit", not "scalardl-auditor")
# Apply with:
#   helm install <release> scalar-labs/scalardl-audit -f scalardl-auditor-custom-values.yaml
#
# Required Kubernetes Secrets (provisioned by ./scripts/create-scalardl-secrets.sh
# from environment variables sourced from ./env.sh — see ./scripts/env-template.sh).
#
# auditor-credentials-secret (always — license + DB cred + HMAC when applicable):
#   AUDITOR_LICENSE_KEY          ← env: AUDITOR_LICENSE_KEY
#   LICENSE_CHECK_CERT_PEM       ← env: LICENSE_CHECK_CERT_PEM
#   SCALAR_DB_USERNAME           ← env: AUDITOR_DB_USERNAME
#   SCALAR_DB_PASSWORD           ← env: AUDITOR_DB_PASSWORD
{{#hmacPattern}}
#   AUDITOR_HMAC_CIPHER_KEY      ← env: AUDITOR_HMAC_CIPHER_KEY  (HMAC pattern)
#   SERVERS_HMAC_SECRET_KEY      ← env: SERVERS_HMAC_SECRET_KEY  (same value as ledger Secret — server-server shared)
{{/hmacPattern}}
{{#dsPattern}}
#
# auditor-key-secret (DS pattern — PKI files mounted, NOT env-var):
#   auditor-key-file             ← ./cert/auditor-key.pem
#   auditor-cert-file            ← ./cert/auditor-cert.pem
{{/dsPattern}}

auditor:
  replicaCount: {{auditorReplicaCount}}

  # Top-level secretName (chart field): credentials Secret consumed via envFrom.
  # Pod gets AUDITOR_LICENSE_KEY / SCALAR_DB_USERNAME / SCALAR_DB_PASSWORD /
  # LICENSE_CHECK_CERT_PEM / (AUDITOR_HMAC_CIPHER_KEY) / (SERVERS_HMAC_SECRET_KEY)
  # from this Secret via envFrom.
  secretName: auditor-credentials-secret

  # Authentication method at chart level. Gates the chart's /keys auto-mount:
  # if "hmac", the chart skips the volume + volumeMount for the PKI Secret.
  authentication:
    method: {{authMethod}}

  scalarAuditorConfiguration:
    auditorLedgerHost: {{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local
    auditorServerPort: {{auditorPort}}
    auditorServerPrivilegedPort: {{auditorPrivilegedPort}}
    auditorServerAdminPort: {{auditorAdminPort}}
{{#dsPattern}}
    # PKI Secret: chart auto-mounts this at /keys/ when authentication.method
    # is NOT "hmac" AND extraVolumes is unset (line 44 of chart's deployment.yaml).
    # The credentials Secret above is consumed via envFrom (different mechanism).
    secretName: auditor-key-secret
    auditorCertHolderId: {{auditorCertHolderId}}
    auditorCertVersion: {{auditorCertVersion}}
    auditorCertSecretKey: auditor-cert-file
    auditorPrivateKeySecretKey: auditor-key-file
{{/dsPattern}}

  # Override auditorProperties to take full control of the properties file the
  # Auditor pod reads at startup.
  auditorProperties: |
    # === Identity / namespace ===
    scalar.dl.auditor.name={{auditorName}}
    scalar.dl.auditor.namespace=auditor

    # === Authentication (Client ↔ Auditor) ===
    scalar.dl.auditor.authentication.method={{authMethod}}
{{#hmacPattern}}
    # Sourced from auditor-credentials-secret (key: AUDITOR_HMAC_CIPHER_KEY).
    scalar.dl.auditor.authentication.hmac.cipher_key=${env:AUDITOR_HMAC_CIPHER_KEY}
{{/hmacPattern}}

    # === Auditor identity ===
{{#dsPattern}}
    scalar.dl.auditor.cert_holder_id={{auditorCertHolderId}}
    scalar.dl.auditor.cert_version={{auditorCertVersion}}
    scalar.dl.auditor.private_key_path=/keys/auditor-key-file
{{/dsPattern}}

    # === Ledger connection (server-server) ===
    scalar.dl.auditor.ledger.host={{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local
    scalar.dl.auditor.ledger.port={{ledgerPort}}
    scalar.dl.auditor.ledger.privileged_port={{ledgerPrivilegedPort}}

{{#dsPattern}}
    # DS server-server: lookup Ledger's registered cert by holder id + version
    scalar.dl.auditor.ledger.cert_holder_id={{ledgerCertHolderId}}
    scalar.dl.auditor.ledger.cert_version={{ledgerCertVersion}}
{{/dsPattern}}
{{#hmacPattern}}
    # HMAC server-server: shared secret_key (MUST match Ledger's value).
    # Sourced from auditor-credentials-secret (key: SERVERS_HMAC_SECRET_KEY,
    # same value as ledger-credentials-secret's SERVERS_HMAC_SECRET_KEY).
    scalar.dl.auditor.servers.authentication.hmac.secret_key=${env:SERVERS_HMAC_SECRET_KEY}
{{/hmacPattern}}

    # === Server ports ===
    scalar.dl.auditor.server.port={{auditorPort}}
    scalar.dl.auditor.server.privileged_port={{auditorPrivilegedPort}}
    scalar.dl.auditor.server.admin_port={{auditorAdminPort}}
    scalar.dl.auditor.server.prometheus_exporter_port={{auditorPrometheusPort}}

{{#tlsEnabled}}
    # === TLS (Client ↔ Auditor) ===
    # Chart auto-mounts the Secrets configured in `auditor.tls.*` below at
    # /tls/scalardl-auditor/certs/ with file names ca.crt / tls.crt / tls.key.
    scalar.dl.auditor.server.tls.enabled=true
    scalar.dl.auditor.server.tls.cert_chain_path=/tls/scalardl-auditor/certs/tls.crt
    scalar.dl.auditor.server.tls.private_key_path=/tls/scalardl-auditor/certs/tls.key
{{/tlsEnabled}}
{{#tlsServerServer}}
    # === TLS (Auditor → Ledger, server-server client-side) ===
    # The Auditor connects to the Ledger envoy svc over TLS for cross-validation.
    # Re-use the Ledger's own TLS cert as trust anchor (self-signed).
    scalar.dl.auditor.tls.enabled=true
    scalar.dl.auditor.tls.ca_root_cert_path=/tls/scalardl-auditor/certs/ca.crt
{{/tlsServerServer}}

    # === ScalarDB (Auditor-side storage; MUST be different from Ledger's) ===
    # contact_points / storage are non-sensitive and baked in at render time.
    # username / password come from auditor-credentials-secret via extraEnvFrom.
    scalar.db.contact_points={{auditorScalarDbContactPoints}}
    scalar.db.username=${env:SCALAR_DB_USERNAME}
    scalar.db.password=${env:SCALAR_DB_PASSWORD}
    scalar.db.storage={{auditorScalarDbStorage}}

{{#licensing}}
    # === License (Enterprise) ===
    # Both values come from auditor-credentials-secret via extraEnvFrom. The
    # AUDITOR_LICENSE_KEY is Auditor-specific (different from LEDGER_LICENSE_KEY)
    # per Scalar Inc. licensing model.
    scalar.dl.licensing.license_key=${env:AUDITOR_LICENSE_KEY}
    scalar.dl.licensing.license_check_cert_pem=${env:LICENSE_CHECK_CERT_PEM}
{{/licensing}}

  # NOTE: We do NOT emit `extraEnvFrom` (chart honors only top-level `auditor.
  # secretName` for envFrom). And we do NOT emit `extraVolumes` for the PKI
  # Secret (chart auto-mounts at /keys/ when authentication.method != "hmac"
  # + extraVolumes is unset). Setting extraVolumes here would suppress the
  # auto-mount and force us to manually mount /keys, which is a more complex
  # path than necessary for the common case.
  #
  # TLS (Client↔Auditor, Server-Server) is handled by the chart's own
  # `auditor.tls.*` fields, not by our extraVolumes — see Phase 4 A4h.
{{#tlsEnabled}}

  # TLS at the Auditor pod (chart's native fields). See ledger.tls comment in
  # scalardl-ledger-custom-values.yaml for the design rationale.
  # caRootCertForLedgerSecret: chart-specific to scalardl-audit — provides
  # the CA cert the Auditor uses to verify the Ledger's server cert during
  # Auditor → Ledger cross-validation calls. Reuse `ledger-tls` (carries
  # ca.crt = Ledger's self-signed cert).
  tls:
    enabled: true
    caRootCertSecret: auditor-tls
    certChainSecret: auditor-tls
    privateKeySecret: auditor-tls
    caRootCertForLedgerSecret: ledger-tls
    overrideAuthority: {{auditorName}}-envoy.{{auditorNamespace}}.svc.cluster.local
{{/tlsEnabled}}

{{#envoyLoadBalancer}}
# === Envoy (admin CLI / external reachability) ===
# The bundled Envoy sub-chart is enabled by chart default (envoy.enabled: true)
# and fronts the Auditor pods. We override service.type to LoadBalancer so that
# `helm install` provisions a cloud-provider LoadBalancer with an external IP.
# After `helm install`, get the IP with:
#   kubectl get svc {{auditorName}}-envoy -n {{auditorNamespace}} \
#     -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
# Then replace <AUDITOR_EXTERNAL_IP> in auditor.as.client.properties with that IP.
# (Cloud-provider-specific annotations — AWS NLB / GKE Internal LB / Azure
#  Internal LB — are intentionally NOT emitted by the skill. Add envoy.service.
#  annotations here by hand if your environment needs them.)
envoy:
  replicaCount: {{envoyReplicaCount}}
  service:
    type: LoadBalancer
{{#tlsEnabled}}
  tls:
    downstream:
      enabled: true
      certChainSecret: auditor-tls
      privateKeySecret: auditor-tls
    upstream:
      enabled: true
      overrideAuthority: {{auditorName}}-envoy.{{auditorNamespace}}.svc.cluster.local
      caRootCertSecret: auditor-tls
{{/tlsEnabled}}
{{/envoyLoadBalancer}}

# Reminder: Auditor must use a SEPARATE ScalarDB infrastructure from Ledger.
# Otherwise both servers share a fault domain, defeating Byzantine detection.
# (See plan-008 D2 + references/scalardl-configurations.md § Auditor 設定.)
