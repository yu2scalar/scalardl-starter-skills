# Reference (synced): skills/scalardl-generate-config/references/scalardl-configurations.md
# Generated at: {{generatedAt}}
# Target ScalarDL: {{targetVersion}}+
# Helm chart: scalardl (Ledger). Apply with:
#   helm install <release> scalar-labs/scalardl -f scalardl-ledger-custom-values.yaml
#
# Required Kubernetes Secrets (provisioned by ./scripts/create-scalardl-secrets.sh
# from environment variables sourced from ./env.sh — see ./scripts/env-template.sh).
#
# ledger-credentials-secret (always — license + DB cred + HMAC when applicable):
#   LEDGER_LICENSE_KEY           ← env: LEDGER_LICENSE_KEY
#   LICENSE_CHECK_CERT_PEM       ← env: LICENSE_CHECK_CERT_PEM
#   SCALAR_DB_USERNAME           ← env: LEDGER_DB_USERNAME
#   SCALAR_DB_PASSWORD           ← env: LEDGER_DB_PASSWORD
{{#hmacPattern}}
#   LEDGER_HMAC_CIPHER_KEY       ← env: LEDGER_HMAC_CIPHER_KEY  (HMAC pattern)
{{#auditor}}
#   SERVERS_HMAC_SECRET_KEY      ← env: SERVERS_HMAC_SECRET_KEY (HMAC + Auditor=Yes; same value in auditor Secret)
{{/auditor}}
{{/hmacPattern}}
{{#dsPattern}}
#
# ledger-key-secret (DS pattern — PKI file mount, NOT env-var):
#   ledger-key-file              ← ./cert/ledger-key.pem
{{/dsPattern}}

ledger:
  replicaCount: {{ledgerReplicaCount}}

  # Top-level secretName (chart field): credentials Secret consumed via envFrom.
  # The chart's deployment.yaml emits:
  #   {{- if .Values.ledger.secretName }}
  #   envFrom:
  #   - secretRef:
  #       name: "{{ .Values.ledger.secretName }}"
  #   {{- end }}
  # So Pod gets LEDGER_LICENSE_KEY / SCALAR_DB_USERNAME / SCALAR_DB_PASSWORD /
  # LICENSE_CHECK_CERT_PEM / (LEDGER_HMAC_CIPHER_KEY) / (SERVERS_HMAC_SECRET_KEY)
  # as env vars from this Secret.
  secretName: ledger-credentials-secret

  scalarLedgerConfiguration:
    # Auditor coupling (set programmatically by the skill from A1)
    ledgerAuditorEnabled: {{auditor}}
    # AssetProof toggle (set programmatically by the skill from A3 / A1)
    ledgerProofEnabled: {{proofEnabled}}
{{#dsPattern}}
    # PKI Secret: when ledgerProofEnabled is true, the chart auto-mounts this
    # Secret at /keys/ via volumeMount, exposing each Secret key as a file.
    # `ledgerPrivateKeySecretKey` is the file name inside /keys/ that
    # `scalar.dl.ledger.proof.private_key_path` should reference.
    # NOTE: this MUST be the PKI Secret (ledger-key-secret), NOT the
    # credentials Secret above — they are mounted by different mechanisms
    # (file vs envFrom) and conflating them creates a duplicate /keys mount.
    secretName: ledger-key-secret
    ledgerPrivateKeySecretKey: ledger-key-file
{{/dsPattern}}
{{#hmacPattern}}
{{#proofEnabled}}
    # HMAC + proof.enabled=true: AssetProof signing falls back to DS, so the
    # chart still auto-mounts /keys/. Mount our PKI Secret. Applies to both
    # standalone (counterintuitive) and Auditor=Yes (chart-forced proof.enabled)
    # configurations.
    secretName: ledger-key-secret
    ledgerPrivateKeySecretKey: ledger-key-file
{{/proofEnabled}}
{{/hmacPattern}}

  # Override ledgerProperties to take full control of the properties file the
  # Ledger pod reads at startup. Default template in the chart only covers a
  # subset of properties; we need finer control for HMAC, cert_holder_id, TLS,
  # AssetProof, etc.
  ledgerProperties: |
    # === Identity / namespace ===
    scalar.dl.ledger.name={{ledgerName}}
    scalar.dl.ledger.namespace=scalar

    # === Authentication (Client ↔ Ledger) ===
    scalar.dl.ledger.authentication.method={{authMethod}}
{{#hmacPattern}}
    # HMAC encryption key for client entity HMAC secrets at rest.
    # Sourced from ledger-credentials-secret (key: LEDGER_HMAC_CIPHER_KEY).
    scalar.dl.ledger.authentication.hmac.cipher_key=${env:LEDGER_HMAC_CIPHER_KEY}
{{/hmacPattern}}

    # === AssetProof signing ===
    scalar.dl.ledger.proof.enabled={{proofEnabled}}
{{#proofEnabled}}
{{#dsPattern}}
    # DS-signed AssetProof: private key from mounted Secret (ledger-key-secret)
    scalar.dl.ledger.proof.private_key_path=/keys/ledger-key-file
{{/dsPattern}}
{{#hmacPattern}}
{{#auditor}}
    # HMAC-signed AssetProof: uses the same key as Ledger ↔ Auditor server-server
    # secret_key is set below in the "Auditor coupling" section
{{/auditor}}
{{^auditor}}
    # Standalone Ledger × HMAC client + proof.enabled=true: counterintuitively
    # requires a DS private key because servers.authentication.hmac.secret_key
    # is only populated when auditor.enabled=true. Skill emits the DS key
    # (ledger-key-secret mounted as file at /keys/ledger-key-file).
    scalar.dl.ledger.proof.private_key_path=/keys/ledger-key-file
{{/auditor}}
{{/hmacPattern}}
{{/proofEnabled}}

{{#auditor}}
    # === Auditor coupling ===
    scalar.dl.ledger.auditor.enabled=true
{{#dsPattern}}
    # DS Server-Server: lookup Auditor's registered cert by holder id + version
    scalar.dl.ledger.auditor.cert_holder_id={{auditorCertHolderId}}
    scalar.dl.ledger.auditor.cert_version={{auditorCertVersion}}
{{/dsPattern}}
{{#hmacPattern}}
    # HMAC Server-Server: shared secret_key (MUST match the Auditor's value).
    # Sourced from ledger-credentials-secret (key: SERVERS_HMAC_SECRET_KEY).
    # start-scalardl.sh exports the same value into auditor-credentials-secret.
    scalar.dl.ledger.servers.authentication.hmac.secret_key=${env:SERVERS_HMAC_SECRET_KEY}
{{/hmacPattern}}
{{/auditor}}

    # === Server ports ===
    scalar.dl.ledger.server.port={{ledgerPort}}
    scalar.dl.ledger.server.privileged_port={{ledgerPrivilegedPort}}
    scalar.dl.ledger.server.admin_port={{ledgerAdminPort}}
    scalar.dl.ledger.server.prometheus_exporter_port={{ledgerPrometheusPort}}

{{#tlsEnabled}}
    # === TLS (Client ↔ Ledger) ===
    # Chart auto-mounts the Secrets configured in `ledger.tls.*` below at
    # /tls/scalardl-ledger/certs/ with file names ca.crt / tls.crt / tls.key.
    scalar.dl.ledger.server.tls.enabled=true
    scalar.dl.ledger.server.tls.cert_chain_path=/tls/scalardl-ledger/certs/tls.crt
    scalar.dl.ledger.server.tls.private_key_path=/tls/scalardl-ledger/certs/tls.key
{{/tlsEnabled}}

    # === ScalarDB (Ledger-side storage) ===
    # contact_points / storage are non-sensitive and baked in at render time.
    # username / password come from ledger-credentials-secret via extraEnvFrom.
    scalar.db.contact_points={{ledgerScalarDbContactPoints}}
    scalar.db.username=${env:SCALAR_DB_USERNAME}
    scalar.db.password=${env:SCALAR_DB_PASSWORD}
    scalar.db.storage={{ledgerScalarDbStorage}}

{{#licensing}}
    # === License (Enterprise) ===
    # Both values come from ledger-credentials-secret via extraEnvFrom (see
    # below). The PEM file lives at <output-dir>/license-pem/{{licenseType}}-cert.pem
    # and is loaded into the env var LICENSE_CHECK_CERT_PEM by env-template.sh,
    # then into the Secret by create-scalardl-secrets.sh.
    scalar.dl.licensing.license_key=${env:LEDGER_LICENSE_KEY}
    scalar.dl.licensing.license_check_cert_pem=${env:LICENSE_CHECK_CERT_PEM}
{{/licensing}}

{{#tlsEnabled}}
  # TLS at the Ledger pod (chart's native fields). The chart auto-mounts the
  # referenced Secrets at /tls/scalardl-ledger/certs and emits the right
  # envoy_upstream_tls env so the bundled Envoy can connect upstream over TLS.
  # All three secrets point at the same Secret name `ledger-tls` carrying:
  #   ca.crt   ← ./cert/ledger-tls-cert.pem (self-signed = its own CA)
  #   tls.crt  ← ./cert/ledger-tls-cert.pem
  #   tls.key  ← ./cert/ledger-tls-key.pem
  # (see scripts/create-scalardl-secrets.sh)
  tls:
    enabled: true
    caRootCertSecret: ledger-tls
    certChainSecret: ledger-tls
    privateKeySecret: ledger-tls
    overrideAuthority: {{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local
{{/tlsEnabled}}
  # NOTE: We do NOT emit `extraEnvFrom` (chart does not honor this field — it
  # only uses the top-level `ledger.secretName` for envFrom). And we do NOT
  # emit `extraVolumes`/`extraVolumeMounts` for the PKI Secret (chart auto-
  # mounts at /keys/ when ledgerProofEnabled=true + scalarLedgerConfiguration.
  # secretName is set above).

{{#envoyLoadBalancer}}
# === Envoy (admin CLI / external reachability) ===
# The bundled Envoy sub-chart is enabled by chart default (envoy.enabled: true)
# and fronts the Ledger pods. We override service.type to LoadBalancer so that
# `helm install` provisions a cloud-provider LoadBalancer with an external IP.
# After `helm install`, get the IP with:
#   kubectl get svc {{ledgerName}}-envoy -n {{ledgerNamespace}} \
#     -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
# Then replace <LEDGER_EXTERNAL_IP> in ledger.as.client.properties with that IP.
# (Cloud-provider-specific annotations — AWS NLB / GKE Internal LB / Azure
#  Internal LB — are intentionally NOT emitted by the skill. Add envoy.service.
#  annotations here by hand if your environment needs them.)
envoy:
  replicaCount: {{envoyReplicaCount}}
  service:
    type: LoadBalancer
{{#tlsEnabled}}
  # downstream = client → envoy TLS termination.
  # upstream   = envoy → Ledger TLS re-encryption.
  # Both reuse the same `ledger-tls` Secret as Ledger pod (single self-signed
  # cert per server makes the cert chain trivial for getting-started).
  tls:
    downstream:
      enabled: true
      certChainSecret: ledger-tls
      privateKeySecret: ledger-tls
    upstream:
      enabled: true
      overrideAuthority: {{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local
      caRootCertSecret: ledger-tls
{{/tlsEnabled}}
{{/envoyLoadBalancer}}

# scalar.db.* settings shown above are passthrough; configure separately for
# advanced ScalarDB options (cross_partition_scan, isolation level, etc.) by
# editing this YAML.
