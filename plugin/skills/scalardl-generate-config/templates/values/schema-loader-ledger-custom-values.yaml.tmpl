# Helm chart: schema-loading
# Purpose: create ScalarDL system tables (asset / asset_metadata) in the
# Ledger's ScalarDB instance.
#
# Apply with:
#   helm install <release>-schema-loader-ledger scalar-labs/schema-loading \
#     -f schema-loader-ledger-custom-values.yaml
# After the Job completes successfully, the Ledger pod can start.

schemaLoading:
  # Type of schema to apply: "ledger" creates DL system tables in the Ledger DB
  schemaType: ledger

  # databaseProperties = full ScalarDB config. When set, the chart mounts this
  # as /scalardl-schema-loader/database.properties and the Job runs with
  # `--config database.properties` — it ignores top-level username/password/
  # contactPoints fields entirely. We use this path so credentials stay as
  # ${env:VAR} references (resolved from the consolidated Secret below).
  databaseProperties: |
    scalar.db.contact_points={{ledgerScalarDbContactPoints}}
    scalar.db.username=${env:SCALAR_DB_USERNAME}
    scalar.db.password=${env:SCALAR_DB_PASSWORD}
    scalar.db.storage={{ledgerScalarDbStorage}}

  # Mount ledger-credentials-secret via envFrom so SCALAR_DB_USERNAME /
  # SCALAR_DB_PASSWORD are populated for the ${env:VAR} substitution above.
  secretName: ledger-credentials-secret

  # commandArgs: customize as needed (e.g. --replication-factor for Cassandra clusters)
  # See helm-charts/charts/schema-loading/values.yaml for available flags.
  commandArgs: []

# Notes:
# - Run this Job BEFORE installing the Ledger Helm release. The Job creates the
#   tables that the Ledger expects to exist at startup.
# - Re-running the Job is idempotent (the schema-loader detects existing tables);
#   use `commandArgs: ["--alter"]` if you need to migrate after a ScalarDL upgrade.
# - For production, consider using `existingSecret` to avoid putting credentials
#   in this file. See helm-charts/charts/schema-loading/README.md.
