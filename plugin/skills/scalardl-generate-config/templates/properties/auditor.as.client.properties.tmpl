# Generated by scalardl-starter-skills/scalardl-generate-config (Auditor=Yes only)
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
# Target ScalarDL: {{targetVersion}}+
#
# Purpose: cert / secret registration for the **Auditor server's own entity**.
# This file's `scalar.dl.client.entity.id=auditor` represents the AUDITOR
# SERVER, not a human operator. The Auditor needs its own registered cert on
# the network so its signatures (server-to-Ledger cross-validation, etc.) can
# be verified. This file is used **once during deployment** to register that
# cert:
#
#   scalardl register-cert   --properties auditor.as.client.properties  [DS]
#   scalardl register-secret --properties auditor.as.client.properties  [HMAC]
#
# Application-side operations (register-contract / register-function /
# execute-contract) are NOT done with this file — they go through
# client.properties (which has scalar.dl.client.entity.id=client).
#
# Pre-plan-010 versions of this skill mislabelled this file as the "admin"
# entity. It is not; it is the Auditor server's own cert holder identity.
#
# How to run (envoy-loadbalancer mode):
#   1. helm install ... (the chart provisions svc/{{auditorName}}-envoy as type=LoadBalancer)
#   2. Get external IP:
#        kubectl get svc {{auditorName}}-envoy -n {{auditorNamespace}} \
#          -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
#   3. Replace <AUDITOR_EXTERNAL_IP> in scalar.dl.client.server.host below with that IP.
#   4. scalardl register-cert --properties auditor.as.client.properties
#
# How to run (port-forward mode):
#   kubectl port-forward svc/{{auditorName}}-envoy {{auditorPort}}:{{auditorPort}} {{auditorPrivilegedPort}}:{{auditorPrivilegedPort}}
#   scalardl register-cert --properties auditor.as.client.properties
#
# How to run (external mode):
#   scalardl register-cert --properties auditor.as.client.properties

# === Connection (Ledger primary + Auditor via SDK fan-out) ===
# Per the ScalarDL 3.x reference (~/dl/3.11.dsig/auditor.as.client.properties),
# this file's `server.host` points at the LEDGER and `auditor.host` at the
# AUDITOR. With `auditor.enabled=true`, the Java SDK
# (DefaultClientServiceHandler.registerCertificate at L58-61) fans out each
# register-cert call to BOTH `LedgerPrivileged/RegisterCert` (Ledger) AND
# `AuditorPrivileged/RegisterCert` (Auditor) — both RPCs are implemented in
# v3.13.0 (proto: scalar.proto:59, server: AuditorPrivilegedService.java:34).
# The only thing that distinguishes this file from ledger.as.client.properties
# is `entity.id=auditor` (so the auditor's own cert holder gets registered,
# not the ledger's).
#
# Historical note: pointing `server.host` at the Auditor (instead of the
# Ledger) fails with `UNIMPLEMENTED: rpc.LedgerPrivileged/RegisterCert`
# because LedgerClient.java:109 hard-codes the LedgerPrivileged stub — the
# Auditor only exposes `AuditorPrivileged`, not `LedgerPrivileged`. The
# canonical setup is therefore: server.host=Ledger + auditor.enabled=true
# + auditor.host=Auditor → SDK fan-out handles both.
scalar.dl.client.server.host={{adminLedgerHost}}
scalar.dl.client.server.port={{ledgerPort}}
scalar.dl.client.server.privileged_port={{ledgerPrivilegedPort}}

scalar.dl.client.auditor.enabled=true
scalar.dl.client.auditor.host={{adminAuditorHost}}
scalar.dl.client.auditor.port={{auditorPort}}
scalar.dl.client.auditor.privileged_port={{auditorPrivilegedPort}}

# === Authentication (this is the AUDITOR SERVER's own identity) ===
scalar.dl.client.authentication.method={{authMethod}}
scalar.dl.client.entity.id=auditor
{{#dsPattern}}
scalar.dl.client.entity.identity.digital_signature.cert_path=./cert/auditor-cert.pem
scalar.dl.client.entity.identity.digital_signature.cert_version={{auditorCertVersion}}
scalar.dl.client.entity.identity.digital_signature.private_key_path=./cert/auditor-key.pem
{{/dsPattern}}
{{#hmacPattern}}
# HMAC secret_key for the Auditor entity. For the smoke test path this is read
# from the AUDITOR_HMAC_CIPHER_KEY env var injected by start-scalardl.sh; for
# manual runs replace the placeholder below with the same value.
scalar.dl.client.entity.identity.hmac.secret_key=${AUDITOR_HMAC_CIPHER_KEY}
scalar.dl.client.entity.identity.hmac.secret_key_version=1
{{/hmacPattern}}

{{#tlsEnabled}}
# === TLS (Client ↔ Ledger primary; Auditor cross-validation) ===
# Note: this file's primary connection is to the LEDGER envoy (see server.host
# above), even though entity.id=auditor. So tls.* targets the Ledger cert.
# auditor.tls.* targets the Auditor cert for cross-validation.
scalar.dl.client.tls.enabled=true
{{#tlsClientLedgerCaPath}}scalar.dl.client.tls.ca_root_cert_path={{tlsClientLedgerCaPath}}{{/tlsClientLedgerCaPath}}
scalar.dl.client.tls.override_authority={{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local
scalar.dl.client.auditor.tls.enabled=true
{{#tlsClientAuditorCaPath}}scalar.dl.client.auditor.tls.ca_root_cert_path={{tlsClientAuditorCaPath}}{{/tlsClientAuditorCaPath}}
scalar.dl.client.auditor.tls.override_authority={{auditorName}}-envoy.{{auditorNamespace}}.svc.cluster.local
{{/tlsEnabled}}
