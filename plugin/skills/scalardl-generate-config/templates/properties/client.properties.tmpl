# Generated by scalardl-starter-skills/scalardl-generate-config (plan-010)
# Plan: plan-010 (M2 client.properties extension)
# Generated at: {{generatedAt}}
# Target ScalarDL: {{targetVersion}}+
#
# Purpose: Runtime Client config for the application that calls Contract /
# Function execution. Use for:
#   - register-cert       (DS — register the client entity once before first execute)
#   - register-secret     (HMAC — same)
#   - execute-contract    (call a registered Contract, optionally with a Function)
#   - list-contracts      (enumerate registered Contracts)
#   - validate-ledger     (cryptographic chain validation)
#
# When Auditor is enabled, the client SDK performs Ledger ↔ Auditor cross-
# validation automatically — `scalar.dl.client.auditor.enabled=true` is set
# below so each call goes to BOTH servers and proofs are cross-signed.
#
# This file complements `{ledger,auditor}.as.client.properties` (admin
# entity, register-contract / register-function only). admin and client
# are SEPARATE entities with separate certs / secrets / Ledger registrations.
#
# How to run (envoy-loadbalancer mode — A4g):
#   1. helm install ... (the chart provisions svc/{{ledgerName}}-envoy as type=LoadBalancer)
#   2. Get external IP(s):
#        LEDGER_IP=$(kubectl get svc {{ledgerName}}-envoy -n {{ledgerNamespace}} -o jsonpath='{.status.loadBalancer.ingress[0].ip}')
#{{#auditor}}        AUDITOR_IP=$(kubectl get svc {{auditorName}}-envoy -n {{auditorNamespace}} -o jsonpath='{.status.loadBalancer.ingress[0].ip}')
#{{/auditor}}
#   3. Replace <LEDGER_EXTERNAL_IP>{{#auditor}} / <AUDITOR_EXTERNAL_IP>{{/auditor}} in this file with the IP(s).
#   4. scalardl register-cert    --properties client.properties     # DS
#      scalardl register-secret  --properties client.properties     # HMAC
#   5. scalardl execute-contract --properties client.properties \
#        --contract-id <id> --contract-argument '{"...": ...}'

# === Connection (Ledger) ===
scalar.dl.client.server.host={{adminLedgerHost}}
scalar.dl.client.server.port={{ledgerPort}}
scalar.dl.client.server.privileged_port={{ledgerPrivilegedPort}}

{{#auditor}}
# === Auditor cross-validation (Auditor=Yes) ===
# Client SDK contacts both Ledger and Auditor on every execute-contract
# call so Asset proofs are cross-signed.
scalar.dl.client.auditor.enabled=true
scalar.dl.client.auditor.host={{adminAuditorHost}}
scalar.dl.client.auditor.port={{auditorPort}}
scalar.dl.client.auditor.privileged_port={{auditorPrivilegedPort}}
{{/auditor}}
{{^auditor}}
# Auditor cross-validation is disabled (no Auditor deployed in this config).
scalar.dl.client.auditor.enabled=false
{{/auditor}}

# === Authentication (Client ↔ Ledger {{#auditor}}/ Auditor {{/auditor}}) ===
scalar.dl.client.authentication.method={{authMethod}}
scalar.dl.client.entity.id={{clientEntityId}}
{{#dsPattern}}
scalar.dl.client.entity.identity.digital_signature.cert_path=./cert/client-cert.pem
scalar.dl.client.entity.identity.digital_signature.cert_version={{clientCertVersion}}
scalar.dl.client.entity.identity.digital_signature.private_key_path=./cert/client-key.pem
{{/dsPattern}}
{{#hmacPattern}}
# HMAC secret_key for this client entity. Replace <CLIENT_HMAC_SECRET_KEY>
# below with the runtime app's secret (the same value you'll pass to
# register-secret to bind the client entity to the Ledger). Generate via:
#   openssl rand -base64 32
scalar.dl.client.entity.identity.hmac.secret_key=<CLIENT_HMAC_SECRET_KEY>
scalar.dl.client.entity.identity.hmac.secret_key_version=1
{{/hmacPattern}}

{{#tlsEnabled}}
# === TLS (Client ↔ Ledger{{#auditor}} + Auditor{{/auditor}}) ===
# override_authority pins TLS verification to the server cert's SAN DNS name
# (avoids hostname mismatch when connecting via IP — minikube tunnel exposes
# the envoy LB on 127.0.0.1 but cert is signed for the svc DNS name).
scalar.dl.client.tls.enabled=true
{{#tlsClientLedgerCaPath}}scalar.dl.client.tls.ca_root_cert_path={{tlsClientLedgerCaPath}}{{/tlsClientLedgerCaPath}}
scalar.dl.client.tls.override_authority={{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local
{{#auditor}}
scalar.dl.client.auditor.tls.enabled=true
{{#tlsClientAuditorCaPath}}scalar.dl.client.auditor.tls.ca_root_cert_path={{tlsClientAuditorCaPath}}{{/tlsClientAuditorCaPath}}
scalar.dl.client.auditor.tls.override_authority={{auditorName}}-envoy.{{auditorNamespace}}.svc.cluster.local
{{/auditor}}
{{/tlsEnabled}}
