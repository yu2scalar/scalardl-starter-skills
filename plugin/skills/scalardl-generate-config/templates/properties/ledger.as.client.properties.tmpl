# Generated by scalardl-starter-skills/scalardl-generate-config
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
# Target ScalarDL: {{targetVersion}}+
#
# Purpose: cert / secret registration for the **Ledger server's own entity**.
# This file's `scalar.dl.client.entity.id=ledger` represents the LEDGER SERVER,
# not a human operator. The Ledger needs its own registered cert on the network
# so its signatures (server-to-Auditor cross-validation, internal proofs, etc.)
# can be verified. This file is used **once during deployment** to register
# that cert:
#
#   scalardl register-cert   --properties ledger.as.client.properties  [DS]
#   scalardl register-secret --properties ledger.as.client.properties  [HMAC]
#
# Application-side operations (register-contract / register-function /
# execute-contract) are NOT done with this file — they go through
# client.properties (which has scalar.dl.client.entity.id=client).
#
# Pre-plan-010 versions of this skill mislabelled this file as the "admin"
# entity. It is not; it is the Ledger server's own cert holder identity.
#
# How to run (envoy-loadbalancer mode):
#   1. helm install ... (the chart provisions svc/{{ledgerName}}-envoy as type=LoadBalancer)
#   2. Get external IP:
#        kubectl get svc {{ledgerName}}-envoy -n {{ledgerNamespace}} \
#          -o jsonpath='{.status.loadBalancer.ingress[0].ip}'
#   3. Replace <LEDGER_EXTERNAL_IP> in scalar.dl.client.server.host below with that IP.
#   4. scalardl register-cert --properties ledger.as.client.properties
#
# How to run (port-forward mode):
#   kubectl port-forward svc/{{ledgerName}}-envoy {{ledgerPort}}:{{ledgerPort}} {{ledgerPrivilegedPort}}:{{ledgerPrivilegedPort}}
#   scalardl register-cert --properties ledger.as.client.properties
#
# How to run (external mode):
#   scalardl register-cert --properties ledger.as.client.properties

# === Connection (Ledger primary; Auditor cross-validation when Auditor=Yes) ===
scalar.dl.client.server.host={{adminLedgerHost}}
scalar.dl.client.server.port={{ledgerPort}}
scalar.dl.client.server.privileged_port={{ledgerPrivilegedPort}}

{{#auditor}}
# Auditor SDK fan-out: when Auditor is deployed, the SDK
# (DefaultClientServiceHandler.registerCertificate at L58-61) issues each
# register-cert to BOTH LedgerPrivileged/RegisterCert (this connection) AND
# AuditorPrivileged/RegisterCert (via auditor.host below) when
# auditor.enabled=true. So the Ledger entity's cert lands on both Servers.
scalar.dl.client.auditor.enabled=true
scalar.dl.client.auditor.host={{adminAuditorHost}}
scalar.dl.client.auditor.port={{auditorPort}}
scalar.dl.client.auditor.privileged_port={{auditorPrivilegedPort}}
{{/auditor}}
{{^auditor}}
# No Auditor deployed — register-cert only goes to the Ledger.
scalar.dl.client.auditor.enabled=false
{{/auditor}}

# === Authentication (this is the LEDGER SERVER's own identity) ===
scalar.dl.client.authentication.method={{authMethod}}
scalar.dl.client.entity.id=ledger
{{#dsPattern}}
scalar.dl.client.entity.identity.digital_signature.cert_path=./cert/ledger-cert.pem
scalar.dl.client.entity.identity.digital_signature.cert_version={{ledgerCertVersion}}
scalar.dl.client.entity.identity.digital_signature.private_key_path=./cert/ledger-key.pem
{{/dsPattern}}
{{#hmacPattern}}
# HMAC secret_key for the Ledger entity. For the smoke test path this is read
# from the LEDGER_HMAC_CIPHER_KEY env var injected by start-scalardl.sh; for
# manual runs replace the placeholder below with the same value.
scalar.dl.client.entity.identity.hmac.secret_key=${LEDGER_HMAC_CIPHER_KEY}
scalar.dl.client.entity.identity.hmac.secret_key_version=1
{{/hmacPattern}}

{{#tlsEnabled}}
# === TLS (Client ↔ Ledger{{#auditor}} + Auditor when cross-validation{{/auditor}}) ===
# override_authority pins TLS hostname verification to the cert's SAN DNS name.
scalar.dl.client.tls.enabled=true
{{#tlsClientLedgerCaPath}}scalar.dl.client.tls.ca_root_cert_path={{tlsClientLedgerCaPath}}{{/tlsClientLedgerCaPath}}
scalar.dl.client.tls.override_authority={{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local
{{#auditor}}
scalar.dl.client.auditor.tls.enabled=true
{{#tlsClientAuditorCaPath}}scalar.dl.client.auditor.tls.ca_root_cert_path={{tlsClientAuditorCaPath}}{{/tlsClientAuditorCaPath}}
scalar.dl.client.auditor.tls.override_authority={{auditorName}}-envoy.{{auditorNamespace}}.svc.cluster.local
{{/auditor}}
{{/tlsEnabled}}
