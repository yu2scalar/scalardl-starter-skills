#!/usr/bin/env bash
# Generated by scalardl-starter-skills/scalardl-generate-config
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
#
# Teardown for the deploy created by start-scalardl.sh:
#   1. helm uninstall the 2-4 releases
#   2. delete the Secrets
#   3. delete the namespace (also removes leftover PVCs / ConfigMaps)
#
# Idempotent: --ignore-not-found / `|| true` on every kubectl/helm call.
#
# Does NOT touch the bundle directory (./cert, env.sh, generated yaml) so you
# can re-deploy after fixing config.

set -euo pipefail

NAMESPACE="${NAMESPACE:-{{kubernetesNamespace}}}"

# Helm release names baked in from A4a / A4d at skill-render time.
LEDGER_RELEASE="{{ledgerName}}"
{{#auditor}}
AUDITOR_RELEASE="{{auditorName}}"
{{/auditor}}

echo "Tearing down ScalarDL deploy in namespace: ${NAMESPACE}"

# --- helm uninstall --------------------------------------------------------

{{#auditor}}
helm uninstall "${AUDITOR_RELEASE}"        -n "${NAMESPACE}" 2>/dev/null || true
helm uninstall "${AUDITOR_RELEASE}-schema" -n "${NAMESPACE}" 2>/dev/null || true
{{/auditor}}
helm uninstall "${LEDGER_RELEASE}"        -n "${NAMESPACE}" 2>/dev/null || true
helm uninstall "${LEDGER_RELEASE}-schema" -n "${NAMESPACE}" 2>/dev/null || true

# --- delete Secrets --------------------------------------------------------

kubectl delete secret ledger-credentials-secret  -n "${NAMESPACE}" --ignore-not-found
{{#dsPattern}}
kubectl delete secret ledger-key-secret          -n "${NAMESPACE}" --ignore-not-found
{{/dsPattern}}
{{#auditor}}
kubectl delete secret auditor-credentials-secret -n "${NAMESPACE}" --ignore-not-found
{{#dsPattern}}
kubectl delete secret auditor-key-secret         -n "${NAMESPACE}" --ignore-not-found
{{/dsPattern}}
{{/auditor}}

# --- delete namespace ------------------------------------------------------

# NOTE: This wipes EVERYTHING in the namespace (PVCs, ConfigMaps, etc.). If
# you provisioned the namespace by hand and want to preserve other resources,
# delete the line below and run only the helm/secret cleanup above.
kubectl delete namespace "${NAMESPACE}" --ignore-not-found

echo "Done."
