#!/usr/bin/env bash
# Generated by scalardl-starter-skills/scalardl-generate-config
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
#
# Creates Kubernetes Secrets that the Ledger / Auditor pods reference at
# startup. **All credentials are read from shell environment variables** set
# by sourcing ./env.sh (a user-edited copy of ./env-template.sh).
#
# Secret structure (user pattern — 1 Secret per Server, consolidated):
#   ledger-credentials-secret  — license_key + DB cred + HMAC keys (when HMAC pattern)
#   auditor-credentials-secret — Auditor's license + DB cred + HMAC (when Auditor=Yes)
#   ledger-key-secret          — DS PKI files (when DS pattern, or HMAC+standalone+proof)
#   auditor-key-secret         — DS PKI files (when DS pattern + Auditor=Yes)
#
# Invoked by init-schemas.sh and start-scalardl.sh (both source env.sh first).
# Run directly only when you want to (re)create Secrets without redeploying.
#
# Override NAMESPACE via env var if your release lives elsewhere:
#   NAMESPACE=scalardl-prod ./scripts/create-scalardl-secrets.sh
#
# **Idempotent** — uses `kubectl apply` pattern (`kubectl create ... --dry-run=client -o yaml | kubectl apply -f -`),
# so re-running overwrites Secret contents with the current env-var values
# without erroring on "already exists". Safe to call from both init and start.
# Rotating credentials = update env.sh + re-run the script.
#
# Note: applying a new Secret value does NOT automatically restart Pods that
# already loaded the old values into env. Restart the Server pods explicitly
# (e.g. `kubectl rollout restart` or `helm upgrade`) for the new values to
# take effect.
set -euo pipefail

NAMESPACE="${NAMESPACE:-{{kubernetesNamespace}}}"

# --- Validate required env vars (fail-fast with clear messages) -------------

require_env () {
  local var_name="$1"
  if [ -z "${!var_name:-}" ]; then
    echo "ERROR: \$${var_name} is not set. Source ./env.sh (or set it directly) and re-run." >&2
    echo "       See ./env-template.sh for the full list of required variables." >&2
    exit 1
  fi
}

# Ledger credentials (always required when JDBC backend is used, which is the skill's default)
require_env LEDGER_DB_USERNAME
require_env LEDGER_DB_PASSWORD
{{#licensing}}
require_env LEDGER_LICENSE_KEY
require_env LICENSE_CHECK_CERT_PEM
{{/licensing}}
{{#hmacPattern}}
require_env LEDGER_HMAC_CIPHER_KEY
{{#auditor}}
require_env SERVERS_HMAC_SECRET_KEY
{{/auditor}}
{{/hmacPattern}}
{{#auditor}}
require_env AUDITOR_DB_USERNAME
require_env AUDITOR_DB_PASSWORD
{{#licensing}}
require_env AUDITOR_LICENSE_KEY
{{/licensing}}
{{#hmacPattern}}
require_env AUDITOR_HMAC_CIPHER_KEY
{{/hmacPattern}}
{{/auditor}}

# --- ledger-credentials-secret (consolidated: license + DB + HMAC) ---------

kubectl create secret generic ledger-credentials-secret \
{{#licensing}}
  --from-literal=LEDGER_LICENSE_KEY="${LEDGER_LICENSE_KEY}" \
  --from-literal=LICENSE_CHECK_CERT_PEM="${LICENSE_CHECK_CERT_PEM}" \
{{/licensing}}
  --from-literal=SCALAR_DB_USERNAME="${LEDGER_DB_USERNAME}" \
  --from-literal=SCALAR_DB_PASSWORD="${LEDGER_DB_PASSWORD}" \
{{#hmacPattern}}
  --from-literal=LEDGER_HMAC_CIPHER_KEY="${LEDGER_HMAC_CIPHER_KEY}" \
{{#auditor}}
  --from-literal=SERVERS_HMAC_SECRET_KEY="${SERVERS_HMAC_SECRET_KEY}" \
{{/auditor}}
{{/hmacPattern}}
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -

{{#dsPattern}}
# --- ledger-key-secret (DS pattern: PKI private key as file mount) ---------

# Loads the Ledger's private key into a Secret mounted as a file at
# /keys/ledger-key-file in the Ledger pod. The Helm values reference the
# mount path via `scalar.dl.ledger.proof.private_key_path=/keys/ledger-key-file`.
# Run scripts/generate-server-pki.sh first so ./cert/ledger-key.pem exists.
kubectl create secret generic ledger-key-secret \
  --from-file=ledger-key-file=./cert/ledger-key.pem \
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -
{{/dsPattern}}
{{#hmacPattern}}
{{#proofEnabled}}
# --- ledger-key-secret (HMAC + proof.enabled=true — AssetProof needs DS PKI) ---

# Even though Client↔Ledger auth is HMAC, AssetProof signing falls back to DS,
# so the chart still mounts /keys/ from a Secret. Applies to both standalone
# HMAC + proof (counterintuitive) and Auditor=Yes (chart-forced proof.enabled).
kubectl create secret generic ledger-key-secret \
  --from-file=ledger-key-file=./cert/ledger-key.pem \
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -
{{/proofEnabled}}
{{/hmacPattern}}

{{#auditor}}
# --- auditor-credentials-secret (consolidated: license + DB + HMAC) ---------

kubectl create secret generic auditor-credentials-secret \
{{#licensing}}
  --from-literal=AUDITOR_LICENSE_KEY="${AUDITOR_LICENSE_KEY}" \
  --from-literal=LICENSE_CHECK_CERT_PEM="${LICENSE_CHECK_CERT_PEM}" \
{{/licensing}}
  --from-literal=SCALAR_DB_USERNAME="${AUDITOR_DB_USERNAME}" \
  --from-literal=SCALAR_DB_PASSWORD="${AUDITOR_DB_PASSWORD}" \
{{#hmacPattern}}
  --from-literal=AUDITOR_HMAC_CIPHER_KEY="${AUDITOR_HMAC_CIPHER_KEY}" \
  --from-literal=SERVERS_HMAC_SECRET_KEY="${SERVERS_HMAC_SECRET_KEY}" \
{{/hmacPattern}}
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -

{{#dsPattern}}
# --- auditor-key-secret (DS pattern: PKI key+cert files) -------------------

kubectl create secret generic auditor-key-secret \
  --from-file=auditor-key-file=./cert/auditor-key.pem \
  --from-file=auditor-cert-file=./cert/auditor-cert.pem \
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -
{{/dsPattern}}
{{#hmacPattern}}{{#proofEnabled}}
# --- auditor-key-secret (HMAC + Auditor=Yes: AssetProof needs DS PKI on the Auditor too) ---

kubectl create secret generic auditor-key-secret \
  --from-file=auditor-key-file=./cert/auditor-key.pem \
  --from-file=auditor-cert-file=./cert/auditor-cert.pem \
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -
{{/proofEnabled}}{{/hmacPattern}}
{{/auditor}}

{{#tlsEnabled}}
# --- TLS Secrets (chart's ledger.tls.* / envoy.tls.* expect these) ---------
# Each TLS Secret carries the same self-signed cert+key as both ca.crt and
# tls.crt (CA = cert, since self-signed). Same Secret is referenced by:
#   ledger.tls.certChainSecret / privateKeySecret / caRootCertSecret
#   envoy.tls.downstream.certChainSecret / privateKeySecret
#   envoy.tls.upstream.caRootCertSecret

kubectl create secret generic ledger-tls \
  --from-file=ca.crt=./cert/ledger-tls-cert.pem \
  --from-file=tls.crt=./cert/ledger-tls-cert.pem \
  --from-file=tls.key=./cert/ledger-tls-key.pem \
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -
{{#auditor}}

kubectl create secret generic auditor-tls \
  --from-file=ca.crt=./cert/auditor-tls-cert.pem \
  --from-file=tls.crt=./cert/auditor-tls-cert.pem \
  --from-file=tls.key=./cert/auditor-tls-key.pem \
  -n "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -
{{/auditor}}
{{/tlsEnabled}}

echo "Done. Secrets created in namespace: ${NAMESPACE}"
echo "Verify with: kubectl get secret -n ${NAMESPACE}"
