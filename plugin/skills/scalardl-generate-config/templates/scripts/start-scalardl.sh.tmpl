#!/usr/bin/env bash
# Generated by scalardl-starter-skills/scalardl-generate-config
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
#
# End-to-end Server deploy script for the generated ScalarDL config bundle:
#   1. Source env.sh (assert required env vars)
#   2. Generate HMAC keys via openssl rand (HMAC pattern, if env vars empty)
#   3. helm repo add + update + chart version derivation
#   4. Create namespace
#   5. Generate Server PKI (DS only)
#   6. Create Secrets (license + DB cred + HMAC keys when applicable) —
#      idempotent via `kubectl apply`, safe to re-run
#   7. Install Ledger (+ Auditor when applicable) → wait for Ready
#   8. Print external IP retrieval command (envoy-loadbalancer mode)
#
# **Prerequisite**: schema-loader must have run successfully (see
# scripts/init-schemas.sh). The Server pods will CrashLoopBackOff if the
# expected ScalarDB tables are missing. init-schemas.sh is one-shot — run it
# once per backend DB; this script can be re-run as often as you like.
#
# Re-runnable? YES (Secret creation is idempotent via kubectl apply; helm
# install will of course error on duplicate release names — run
# stop-scalardl.sh first to redeploy with different config).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUNDLE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${BUNDLE_DIR}"

# --- 1. Source env.sh ------------------------------------------------------

if [ ! -f ./env.sh ]; then
  echo "ERROR: ./env.sh not found." >&2
  echo "  Copy env-template.sh first:  cp scripts/env-template.sh env.sh" >&2
  echo "  Then edit env.sh and fill in the values." >&2
  exit 1
fi
# shellcheck source=/dev/null
source ./env.sh

NAMESPACE="${NAMESPACE:-{{kubernetesNamespace}}}"

# Helm release names are baked in from A4a / A4d (the Skill Q&A). Edit the
# values below by re-running the skill, NOT by overriding here — every
# generated file references the same names.
LEDGER_RELEASE="{{ledgerName}}"
{{#auditor}}
AUDITOR_RELEASE="{{auditorName}}"
{{/auditor}}

{{#hmacPattern}}
# --- 2. Generate HMAC keys if unset ---------------------------------------

if [ -z "${LEDGER_HMAC_CIPHER_KEY:-}" ]; then
  export LEDGER_HMAC_CIPHER_KEY="$(openssl rand -base64 32)"
  echo "Generated fresh LEDGER_HMAC_CIPHER_KEY (save back to env.sh for stable redeploy):"
  echo "  export LEDGER_HMAC_CIPHER_KEY='${LEDGER_HMAC_CIPHER_KEY}'"
fi
{{#auditor}}
if [ -z "${AUDITOR_HMAC_CIPHER_KEY:-}" ]; then
  export AUDITOR_HMAC_CIPHER_KEY="$(openssl rand -base64 32)"
  echo "Generated fresh AUDITOR_HMAC_CIPHER_KEY:"
  echo "  export AUDITOR_HMAC_CIPHER_KEY='${AUDITOR_HMAC_CIPHER_KEY}'"
fi
if [ -z "${SERVERS_HMAC_SECRET_KEY:-}" ]; then
  export SERVERS_HMAC_SECRET_KEY="$(openssl rand -base64 32)"
  echo "Generated fresh SERVERS_HMAC_SECRET_KEY (shared Ledger ↔ Auditor):"
  echo "  export SERVERS_HMAC_SECRET_KEY='${SERVERS_HMAC_SECRET_KEY}'"
fi
{{/auditor}}
{{/hmacPattern}}

# --- 3. helm repo add + update + chart version derivation -----------------

helm repo add scalar-labs https://scalar-labs.github.io/helm-charts 2>/dev/null || true
helm repo update scalar-labs

# Pin chart versions to the latest chart that targets SCALARDL_VERSION (from
# env.sh, baked from A0a). This mirrors the pattern documented in
# ~/dl/3.11.hmac/start_dl.sh. `helm search repo -l` lists all versions.
SCALARDL_VERSION="${SCALARDL_VERSION:-{{targetVersion}}}"
LEDGER_CHART_VERSION="$(helm search repo scalar-labs/scalardl -l --output json 2>/dev/null \
  | python3 -c 'import json,sys; rows=json.load(sys.stdin); xs=[r["version"] for r in rows if r["name"]=="scalar-labs/scalardl" and r["app_version"]==sys.argv[1]]; print(xs[0] if xs else "")' "${SCALARDL_VERSION}")"
if [ -z "${LEDGER_CHART_VERSION}" ]; then
  echo "ERROR: no scalar-labs/scalardl chart found for app_version ${SCALARDL_VERSION}." >&2
  echo "  Run \`helm search repo scalar-labs/scalardl -l\` to list available versions," >&2
  echo "  then override SCALARDL_VERSION in env.sh to match an available app_version." >&2
  exit 1
fi
echo "Pinning chart scalar-labs/scalardl to version ${LEDGER_CHART_VERSION} (app ${SCALARDL_VERSION})"
{{#auditor}}
AUDITOR_CHART_VERSION="$(helm search repo scalar-labs/scalardl-audit -l --output json 2>/dev/null \
  | python3 -c 'import json,sys; rows=json.load(sys.stdin); xs=[r["version"] for r in rows if r["name"]=="scalar-labs/scalardl-audit" and r["app_version"]==sys.argv[1]]; print(xs[0] if xs else "")' "${SCALARDL_VERSION}")"
if [ -z "${AUDITOR_CHART_VERSION}" ]; then
  echo "ERROR: no scalar-labs/scalardl-audit chart found for app_version ${SCALARDL_VERSION}." >&2
  exit 1
fi
echo "Pinning chart scalar-labs/scalardl-audit to version ${AUDITOR_CHART_VERSION} (app ${SCALARDL_VERSION})"
{{/auditor}}

# --- 4. Create namespace (idempotent) -------------------------------------

kubectl create namespace "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -

{{#dsPattern}}
# --- 5. Generate Server PKI (DS pattern) -----------------------------------

if [ ! -f ./cert/ledger-key.pem ]; then
  bash scripts/generate-server-pki.sh
else
  echo "PKI already exists at ./cert/ — skipping generation. Delete cert/ to regenerate."
fi
{{/dsPattern}}
{{#hmacPattern}}
{{^auditor}}
{{#proofEnabled}}
# --- 5. Generate Server PKI (counterintuitive HMAC standalone + proof) -----

if [ ! -f ./cert/ledger-key.pem ]; then
  bash scripts/generate-server-pki.sh
fi
{{/proofEnabled}}
{{/auditor}}
{{/hmacPattern}}

# --- 6. Create Secrets -----------------------------------------------------

NAMESPACE="${NAMESPACE}" bash scripts/create-scalardl-secrets.sh

# --- 7. Install ScalarDL Server(s) -----------------------------------------

helm install "${LEDGER_RELEASE}" scalar-labs/scalardl \
  --version "${LEDGER_CHART_VERSION}" \
  -f scalardl-ledger-custom-values.yaml \
  -n "${NAMESPACE}"
kubectl wait --for=condition=Ready --timeout=10m \
  -l "app.kubernetes.io/instance=${LEDGER_RELEASE}" \
  pod -n "${NAMESPACE}"
{{#auditor}}
helm install "${AUDITOR_RELEASE}" scalar-labs/scalardl-audit \
  --version "${AUDITOR_CHART_VERSION}" \
  -f scalardl-auditor-custom-values.yaml \
  -n "${NAMESPACE}"
kubectl wait --for=condition=Ready --timeout=10m \
  -l "app.kubernetes.io/instance=${AUDITOR_RELEASE}" \
  pod -n "${NAMESPACE}"
{{/auditor}}

# --- 8. Print next-steps ---------------------------------------------------

echo ""
echo "============================================================================"
echo "Install complete. Namespace: ${NAMESPACE}"
echo "============================================================================"
echo "Verify pods:"
echo "  kubectl get pods -n ${NAMESPACE}"
echo ""
echo "Get Envoy LoadBalancer external IP (envoy-loadbalancer mode):"
echo "  kubectl get svc ${LEDGER_RELEASE}-envoy -n ${NAMESPACE} -o jsonpath='{.status.loadBalancer.ingress[0].ip}'"
{{#auditor}}
echo "  kubectl get svc ${AUDITOR_RELEASE}-envoy -n ${NAMESPACE} -o jsonpath='{.status.loadBalancer.ingress[0].ip}'"
{{/auditor}}
echo ""
echo "Replace <LEDGER_EXTERNAL_IP> in ledger.as.client.properties with the IP above, then:"
{{#dsPattern}}
echo "  scalardl-client --properties ledger.as.client.properties --command register-cert"
{{/dsPattern}}
{{#hmacPattern}}
echo "  scalardl-client --properties ledger.as.client.properties --command register-secret"
{{/hmacPattern}}
echo ""
echo "Tear down everything:  bash scripts/stop-scalardl.sh"
