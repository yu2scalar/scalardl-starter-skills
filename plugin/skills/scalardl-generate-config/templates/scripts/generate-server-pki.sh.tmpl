#!/usr/bin/env bash
# Generated by scalardl-starter-skills/scalardl-generate-config (DS pattern)
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
#
# Generates ECDSA P-256 (prime256v1 / secp256r1 / NIST P-256) self-signed
# cert + private key pairs for ScalarDL Server-side identities.
#
# Algorithm: SHA256withECDSA × prime256v1 — confirmed via
#   ~/claude/dl/scalardl/common/src/main/java/com/scalar/dl/ledger/crypto/DigitalSignatureSigner.java:21
# (the ScalarDL DigitalSignatureSigner has DEFAULT_ALGORITHM = "SHA256withECDSA"
# and the helm-charts sample keys are prime256v1). See plan-008 D11.
#
# Suitable for getting-started / dev. Production deploys should issue certs
# from a real CA (organization or commercial) and replace these. The cert
# rotation procedure is the same: generate new cert/key, register-cert with
# a NEW cert_version, atomically flip the *.cert_version property on consuming
# servers, then optionally archive the old version.
#
# Identities generated:
#   - ledger : the Ledger pod's signing key (also used in ledger.as.client.properties
#              for the one-time `register-cert` that registers the Ledger server's
#              own cert on the network)
#   {{#auditor}}- auditor: the Auditor pod's signing key (also used in auditor.as.client.properties
#              for the Auditor server's own register-cert)
#   {{/auditor}}- client : the runtime app's identity (used by client.properties to call
#              register-cert / register-contract / register-function /
#              execute-contract / list-contracts / validate-ledger). Plan-010
#              merged the runtime client config into M2.
#
# Note (no separate "admin" entity): pre-plan-010 versions of this script
# generated an `admin-{key,cert}.pem` pair for a separate admin operator
# identity. That was a design error — ScalarDL's ContractEntry is keyed on
# (id, entityId, keyVersion), so a Contract registered by `admin` cannot be
# executed by `client`. Register-contract / register-function / execute-
# contract all run as the `client` entity. The `ledger` and `auditor` identities
# above are SERVER cert holders for cross-validation, not human operators.
#
# Usage:
#   ./scripts/generate-server-pki.sh                       # writes to ./cert/
#   OUT_DIR=/etc/scalardl/cert ./scripts/generate-server-pki.sh
#   VALIDITY_DAYS=730 ./scripts/generate-server-pki.sh
#
# After running, the cert + key files are referenced by:
#   - scalardl-{ledger,auditor}-custom-values.yaml (`extraVolumes` mounts via Secret)
#   - {ledger,auditor}.as.client.properties (`scalar.dl.client.entity.identity.digital_signature.*`)
#   - scripts/create-scalardl-secrets.sh (loads keys into Kubernetes Secrets)
set -euo pipefail

OUT_DIR="${OUT_DIR:-{{pkiOutDir}}}"
OUT_DIR="${OUT_DIR%/}"   # strip trailing slash for consistent path concatenation
CURVE="prime256v1"
VALIDITY_DAYS="${VALIDITY_DAYS:-{{pkiValidityDays}}}"

# Subject defaults — /CN identifies the role; /O / /OU / /C are descriptive.
# For production CAs, expand the subject to match your PKI policy.
SUBJ_BASE="/C=JP/O=Local Development/OU=ScalarDL"

if ! command -v openssl >/dev/null 2>&1; then
  echo "ERROR: openssl is required but not in PATH." >&2
  exit 1
fi

mkdir -p "$OUT_DIR"
chmod 700 "$OUT_DIR"

gen_pair () {
  local name="$1"
  local key="$OUT_DIR/$name-key.pem"
  local cert="$OUT_DIR/$name-cert.pem"

  if [[ -f "$key" || -f "$cert" ]]; then
    echo "ERROR: $key or $cert already exists. Remove the old keys before re-running this script." >&2
    echo "       (Refusing to overwrite to avoid accidentally invalidating registered certs.)" >&2
    exit 2
  fi

  openssl ecparam -genkey -name "$CURVE" -noout -out "$key"
  chmod 600 "$key"
  openssl req -new -x509 -days "$VALIDITY_DAYS" -key "$key" -sha256 \
    -out "$cert" -subj "$SUBJ_BASE/CN=$name"

  if ! openssl ec -in "$key" -noout -text 2>/dev/null | grep -q "ASN1 OID: prime256v1"; then
    echo "WARN: $key was not generated with prime256v1 curve" >&2
  fi
  echo "  generated $name (key=$key cert=$cert)"
}

# gen_tls_pair generates an ECDSA P-256 TLS cert pair WITH SubjectAltName.
# Different from gen_pair (entity signing cert) — TLS cert needs SAN for
# the gRPC hostname so the client's TLS verification passes.
#
# Args: $1 = role (ledger|auditor), $2 = comma-separated SAN list
#       (e.g. "DNS:scalardl-ledger-envoy.ns.svc.cluster.local,IP:127.0.0.1")
gen_tls_pair () {
  local role="$1" sans="$2"
  local key="$OUT_DIR/$role-tls-key.pem"
  local cert="$OUT_DIR/$role-tls-cert.pem"
  local conf="$OUT_DIR/$role-tls-openssl.cnf"

  if [[ -f "$key" || -f "$cert" ]]; then
    echo "  $role-tls already exists, skipping (delete cert/$role-tls-*.pem to regenerate)"
    return 0
  fi

  cat > "$conf" <<EOF
[req]
distinguished_name=req
prompt=no
[v3_req]
subjectAltName=${sans}
basicConstraints=CA:TRUE
keyUsage=digitalSignature,keyCertSign,keyEncipherment
extendedKeyUsage=serverAuth,clientAuth
EOF

  openssl ecparam -genkey -name "$CURVE" -noout -out "$key"
  chmod 600 "$key"
  openssl req -new -x509 -days "$VALIDITY_DAYS" -key "$key" -sha256 \
    -out "$cert" -subj "$SUBJ_BASE/CN=$role-tls" \
    -extensions v3_req -config "$conf"

  echo "  generated $role-tls (key=$key cert=$cert, SANs: ${sans})"
}

echo "Generating ScalarDL Server PKI in $OUT_DIR (curve=$CURVE, validity=${VALIDITY_DAYS} days)"

gen_pair ledger
{{#auditor}}
gen_pair auditor
{{/auditor}}
gen_pair client

{{#tlsEnabled}}
echo ""
echo "Generating TLS certs (for chart's ledger.tls.* / envoy.tls.* Secret refs)..."
# SANs cover: Envoy LoadBalancer LB host (minikube tunnel = 127.0.0.1) +
# the internal svc DNS + localhost for any port-forward variant.
gen_tls_pair ledger "DNS:{{ledgerName}}-envoy.{{ledgerNamespace}}.svc.cluster.local,DNS:{{ledgerName}}-envoy,DNS:localhost,IP:127.0.0.1"
{{#auditor}}
gen_tls_pair auditor "DNS:{{auditorName}}-envoy.{{auditorNamespace}}.svc.cluster.local,DNS:{{auditorName}}-envoy,DNS:localhost,IP:127.0.0.1"
{{/auditor}}
{{/tlsEnabled}}

echo
echo "Done. ${OUT_DIR}/ contents:"
ls -la "$OUT_DIR/"

cat <<'NEXT'

Next steps:
  1) Review the generated certs:
       openssl x509 -in cert/ledger-cert.pem -noout -text | head -20
  2) Load keys into Kubernetes Secrets:
       ./scripts/create-scalardl-secrets.sh
  3) Helm install Ledger + Auditor:
       helm install scalardl-ledger scalar-labs/scalardl    -f scalardl-ledger-custom-values.yaml
       helm install scalardl-auditor scalar-labs/scalardl-audit -f scalardl-auditor-custom-values.yaml
  4) Register the Server-side entities (cross-validation prerequisite):
       scalardl register-cert --properties ledger.as.client.properties      # Ledger's own cert
       scalardl register-cert --properties auditor.as.client.properties     # Auditor's own cert (Auditor=Yes)
  5) Register the runtime client + everything the app needs:
       scalardl register-cert     --properties client.properties
       scalardl register-contract --properties client.properties --contract-id <Id> ...
       scalardl register-function --properties client.properties --function-id <Id> ...
       scalardl execute-contract  --properties client.properties --contract-id <Id> ...
     (Contracts are entity-scoped — client owns its Contracts and must
      self-register them. Functions are globally visible once registered.)
NEXT
