#!/usr/bin/env bash
# Generated by scalardl-starter-skills/scalardl-generate-config
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
#
# HOW TO USE:
#   1. Copy this file: `cp env-template.sh env.sh`
#   2. Edit env.sh, fill in the values
#   3. Add env.sh to .gitignore (NEVER commit secrets to git)
#   4. Source it: `source env.sh`  (or let start-scalardl.sh do it)
#   5. Run `bash scripts/start-scalardl.sh`
#
# env.sh and env-template.sh are independent files — re-running the skill
# overwrites env-template.sh but never touches env.sh. Your edits survive.

# ===========================================================================
# Deployment target (Helm release names baked in from A4a / A4d at render time)
# ===========================================================================
# Override NAMESPACE here if you want to deploy to a different ns than what
# the Q&A captured. The Helm release names ({{ledgerName}}, etc.) are baked
# into start-scalardl.sh / stop-scalardl.sh via Mustache at skill-render time
# and are NOT overridable from env.sh — re-run the skill if you need to change
# them.
export NAMESPACE="{{kubernetesNamespace}}"

# ===========================================================================
# Target ScalarDL version (used by start-scalardl.sh to pin Helm chart version)
# ===========================================================================
# Baked in from A0a at skill-render time. Override here only if you need to
# install a chart version targeting a different ScalarDL version. start-
# scalardl.sh derives the matching chart version via:
#   helm search repo scalar-labs/scalardl -l | grep -F "${SCALARDL_VERSION}" | ...
export SCALARDL_VERSION="{{targetVersion}}"

{{#licensing}}
# ===========================================================================
# License (Scalar Inc. Enterprise — required for production builds)
# ===========================================================================
# Obtain from Scalar Inc. The literal JSON token, NOT a path.
# Ledger and Auditor have SEPARATE license keys (different products).
#
# NOTE: when pasting a long license token, terminal / editor line-wrapping
# can silently inject literal newlines into the value. The Auditor pod's
# license check parses this as JSON and rejects embedded newlines with
# `Illegal unquoted character (CTRL-CHAR, code 10)`. The strip below
# defensively removes \r and \n from the values just before use so a
# broken paste doesn't break the deploy.
export LEDGER_LICENSE_KEY=''        # e.g. '{"organization_name":"Acme","product_name":"ScalarDL Ledger",...}'
{{#auditor}}
export AUDITOR_LICENSE_KEY=''       # e.g. '{"organization_name":"Acme","product_name":"ScalarDL Auditor",...}'
{{/auditor}}

# Defensive strip of accidental newlines in license tokens (see NOTE above).
[ -n "${LEDGER_LICENSE_KEY:-}" ] && export LEDGER_LICENSE_KEY="$(printf '%s' "${LEDGER_LICENSE_KEY}" | tr -d '\r\n')"
{{#auditor}}
[ -n "${AUDITOR_LICENSE_KEY:-}" ] && export AUDITOR_LICENSE_KEY="$(printf '%s' "${AUDITOR_LICENSE_KEY}" | tr -d '\r\n')"
{{/auditor}}

# License check cert (X.509 PEM, multi-line).
# **Auto-loaded** from the bundled `{{licenseType}}-cert.pem` if env.sh is
# sourced from the bundle root (which start-scalardl.sh ensures). To use a
# different cert, set LICENSE_CHECK_CERT_PEM explicitly before sourcing.
#
# Keep ACTUAL newlines (not the literal `\n` form). The Auditor pod's
# DigitalSignatureValidator pipes this env var straight into
# CertificateFactory.generateCertificate; with literal `\n` the X509 parser
# fails with "Incomplete data". Ledger tolerated the broken form, Auditor
# crashed on it (verified 2026-05-12 against scalardl-audit 2.12.0).
if [ -z "${LICENSE_CHECK_CERT_PEM:-}" ] && [ -f ./license-pem/{{licenseType}}-cert.pem ]; then
  export LICENSE_CHECK_CERT_PEM="$(cat ./license-pem/{{licenseType}}-cert.pem)"
fi
{{/licensing}}

# ===========================================================================
# Backend DB credentials (PostgreSQL, per `scalar.db.username/password`)
# ===========================================================================
# Ledger and Auditor MUST use independent DB instances (D2 — Byzantine
# fault-detection requires separate management domains). Even if you collapse
# them in dev, set both pairs so the Secrets are populated.
export LEDGER_DB_USERNAME=''
export LEDGER_DB_PASSWORD=''
{{#auditor}}
export AUDITOR_DB_USERNAME=''
export AUDITOR_DB_PASSWORD=''
{{/auditor}}

{{#hmacPattern}}
# ===========================================================================
# HMAC keys (HMAC pattern only)
# ===========================================================================
# These can be LEFT EMPTY here — start-scalardl.sh will generate fresh values
# via `openssl rand -base64 32` and export them at install time. After install,
# save them BACK to env.sh if you want to redeploy with the same keys
# (re-bound clients require stable keys).
#
# A fresh HMAC cipher key is a "new tenant" event for client entities: any
# entities registered with the OLD cipher key cannot decrypt their stored
# HMAC secrets, so they must re-register. For dev / smoke tests, regenerate
# freely. For production, treat these like any other long-lived secret.
export LEDGER_HMAC_CIPHER_KEY=''
{{#auditor}}
export AUDITOR_HMAC_CIPHER_KEY=''
# SERVERS_HMAC_SECRET_KEY MUST be the same value in both Ledger and Auditor
# Secrets — they sign server-server messages with this key.
export SERVERS_HMAC_SECRET_KEY=''
{{/auditor}}

# CLIENT_HMAC_SECRET_KEY is the runtime client entity's HMAC secret. plan-010
# made the runtime client config part of M2. The value flows into:
#   - client.properties: replace <CLIENT_HMAC_SECRET_KEY> with this value
#     (sed -i "s|<CLIENT_HMAC_SECRET_KEY>|${CLIENT_HMAC_SECRET_KEY}|" client.properties)
#   - `scalardl register-secret --properties client.properties` then sends
#     this secret to the Ledger so the entity is recognised
# Generate via: openssl rand -base64 32
export CLIENT_HMAC_SECRET_KEY=''
{{/hmacPattern}}

