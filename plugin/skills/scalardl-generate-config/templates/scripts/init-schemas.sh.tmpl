#!/usr/bin/env bash
# Generated by scalardl-starter-skills/scalardl-generate-config
# Plan: plan-008 (scalardl-generate-config skill design)
# Generated at: {{generatedAt}}
#
# One-shot schema initialization for ScalarDL system tables.
#
# Why this is separate from start-scalardl.sh:
#   The schema-loader is a Kubernetes Job that runs once to create DL system
#   tables (asset / asset_metadata / etc.) in the backend ScalarDB. Once the
#   tables exist, subsequent Server deploys don't need it. Bundling
#   schema-loader install + wait into start-scalardl.sh meant every redeploy
#   waited 30s-5min for a no-op Job to "complete" again.
#
# What this script does:
#   1. Source env.sh (need DB credentials + SCALARDL_VERSION)
#   2. helm repo add scalar-labs + update
#   3. Resolve schema-loading chart version targeting SCALARDL_VERSION
#   4. Create namespace (idempotent via kubectl apply)
#   5. Create credentials Secrets (idempotent via kubectl apply — same script
#      as start-scalardl.sh; safe to call twice)
#   6. helm install <ledger>-schema (+ <auditor>-schema when Auditor=Yes)
#   7. Wait for Job(s) to complete (timeout 5m each)
#
# When to re-run:
#   - First-time setup: yes, before start-scalardl.sh.
#   - After dropping the backend DB / re-provisioning Postgres: yes.
#   - After a Server config change (HMAC rotation, etc.): no, schemas are
#     unaffected; just stop-scalardl.sh + start-scalardl.sh is enough.
#
# Re-running is idempotent at the schema-loader level (it detects existing
# tables and exits successfully), but you'll first need to delete the
# previous Helm release of schema-loader:
#   helm uninstall <ledger>-schema -n <ns>

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUNDLE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${BUNDLE_DIR}"

# --- 1. Source env.sh ------------------------------------------------------

if [ ! -f ./env.sh ]; then
  echo "ERROR: ./env.sh not found." >&2
  echo "  Copy env-template.sh first:  cp scripts/env-template.sh env.sh" >&2
  echo "  Then edit env.sh and fill in the values." >&2
  exit 1
fi
# shellcheck source=/dev/null
source ./env.sh

NAMESPACE="${NAMESPACE:-{{kubernetesNamespace}}}"
LEDGER_RELEASE="{{ledgerName}}"
{{#auditor}}
AUDITOR_RELEASE="{{auditorName}}"
{{/auditor}}

# --- 2. helm repo add + update --------------------------------------------

helm repo add scalar-labs https://scalar-labs.github.io/helm-charts 2>/dev/null || true
helm repo update scalar-labs

# --- 3. Resolve schema-loading chart version ------------------------------

SCALARDL_VERSION="${SCALARDL_VERSION:-{{targetVersion}}}"
SCHEMA_CHART_VERSION="$(helm search repo scalar-labs/schema-loading -l --output json 2>/dev/null \
  | python3 -c 'import json,sys; rows=json.load(sys.stdin); xs=[r["version"] for r in rows if r["name"]=="scalar-labs/schema-loading" and r["app_version"]==sys.argv[1]]; print(xs[0] if xs else "")' "${SCALARDL_VERSION}")"
if [ -z "${SCHEMA_CHART_VERSION}" ]; then
  echo "ERROR: no scalar-labs/schema-loading chart found for app_version ${SCALARDL_VERSION}." >&2
  echo "  Run \`helm search repo scalar-labs/schema-loading -l\` to list available versions," >&2
  echo "  then override SCALARDL_VERSION in env.sh to match an available app_version." >&2
  exit 1
fi
echo "Pinning chart scalar-labs/schema-loading to version ${SCHEMA_CHART_VERSION} (app ${SCALARDL_VERSION})"

# --- 4. Namespace (idempotent) --------------------------------------------

kubectl create namespace "${NAMESPACE}" --dry-run=client -o yaml | kubectl apply -f -

{{#dsPattern}}
# --- 4b. PKI generation (DS pattern — create-scalardl-secrets.sh below mounts
#         ./cert/*.pem as ledger-key-secret / auditor-key-secret, so the files
#         must exist before secrets are applied).
#         Idempotent: generate-server-pki.sh only generates if cert/ is missing.

if [ ! -f ./cert/ledger-key.pem ]; then
  bash scripts/generate-server-pki.sh
else
  echo "PKI already exists at ./cert/ — skipping generation. Delete cert/ to regenerate."
fi

{{/dsPattern}}
{{#hmacPattern}}{{#proofEnabled}}
# --- 4b. PKI generation (HMAC + proof.enabled=true). AssetProof signing always
#         falls back to DS (counterintuitive standalone case AND chart-forced
#         Auditor=Yes case). create-scalardl-secrets.sh below needs
#         ./cert/ledger-key.pem.

if [ ! -f ./cert/ledger-key.pem ]; then
  bash scripts/generate-server-pki.sh
else
  echo "PKI already exists at ./cert/ — skipping generation. Delete cert/ to regenerate."
fi

{{/proofEnabled}}{{/hmacPattern}}
{{#hmacPattern}}
# --- 4c. Generate HMAC keys if unset (HMAC pattern — create-scalardl-secrets.sh
#         below requires LEDGER_HMAC_CIPHER_KEY{{#auditor}} / AUDITOR_HMAC_CIPHER_KEY /
#         SERVERS_HMAC_SECRET_KEY{{/auditor}} env vars to be set.
#         Same logic as start-scalardl.sh: generate via `openssl rand -base64 32`
#         when empty, print so the user can save back to env.sh for stable redeploy.

if [ -z "${LEDGER_HMAC_CIPHER_KEY:-}" ]; then
  export LEDGER_HMAC_CIPHER_KEY="$(openssl rand -base64 32)"
  echo "Generated fresh LEDGER_HMAC_CIPHER_KEY (save back to env.sh for stable redeploy):"
  echo "  export LEDGER_HMAC_CIPHER_KEY='${LEDGER_HMAC_CIPHER_KEY}'"
fi
{{#auditor}}
if [ -z "${AUDITOR_HMAC_CIPHER_KEY:-}" ]; then
  export AUDITOR_HMAC_CIPHER_KEY="$(openssl rand -base64 32)"
  echo "Generated fresh AUDITOR_HMAC_CIPHER_KEY:"
  echo "  export AUDITOR_HMAC_CIPHER_KEY='${AUDITOR_HMAC_CIPHER_KEY}'"
fi
if [ -z "${SERVERS_HMAC_SECRET_KEY:-}" ]; then
  export SERVERS_HMAC_SECRET_KEY="$(openssl rand -base64 32)"
  echo "Generated fresh SERVERS_HMAC_SECRET_KEY (shared Ledger ↔ Auditor):"
  echo "  export SERVERS_HMAC_SECRET_KEY='${SERVERS_HMAC_SECRET_KEY}'"
fi
{{/auditor}}

{{/hmacPattern}}
# --- 5. Secrets (idempotent via kubectl apply) ----------------------------

NAMESPACE="${NAMESPACE}" bash scripts/create-scalardl-secrets.sh

# --- 6. Schema-loader Job(s) ----------------------------------------------

helm install "${LEDGER_RELEASE}-schema" scalar-labs/schema-loading \
  --version "${SCHEMA_CHART_VERSION}" \
  -f schema-loader-ledger-custom-values.yaml \
  -n "${NAMESPACE}"
echo "Waiting for ${LEDGER_RELEASE}-schema Job to complete (up to 5m)..."
kubectl wait --for=condition=complete --timeout=5m \
  "job/${LEDGER_RELEASE}-schema-schema-loading" \
  -n "${NAMESPACE}"
{{#auditor}}
helm install "${AUDITOR_RELEASE}-schema" scalar-labs/schema-loading \
  --version "${SCHEMA_CHART_VERSION}" \
  -f schema-loader-auditor-custom-values.yaml \
  -n "${NAMESPACE}"
echo "Waiting for ${AUDITOR_RELEASE}-schema Job to complete (up to 5m)..."
kubectl wait --for=condition=complete --timeout=5m \
  "job/${AUDITOR_RELEASE}-schema-schema-loading" \
  -n "${NAMESPACE}"
{{/auditor}}

echo ""
echo "============================================================================"
echo "Schemas initialized. Next: bash scripts/start-scalardl.sh"
echo "============================================================================"
