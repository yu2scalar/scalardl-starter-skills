{
  "patternName": "p5-auditor-ds-envoy",
  "description": "Auditor + DS / envoy-loadbalancer / TLS=off. Most-common production shape. proof.enabled=true is forced by chart-level constraint when auditor is enabled.",
  "context": {
    "auditor": true,
    "dsPattern": true,
    "hmacPattern": false,
    "authMethod": "digital-signature",
    "proofEnabled": true,
    "envoyLoadBalancer": true,
    "adminLedgerHost": "<LEDGER_EXTERNAL_IP>",
    "adminAuditorHost": "<AUDITOR_EXTERNAL_IP>",
    "auditorScalarDbContactPoints": "jdbc:postgresql://host.minikube.internal:5433/auditor",
    "tlsEnabled": false,
    "tlsServerServer": false,
    "licensing": true
  }
}
